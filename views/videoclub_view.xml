<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción de Ventana para Materials -->
    <record id="action_stickers_material_list" model="ir.actions.act_window">
        <field name="name">Materials</field>
        <field name="res_model">material</field>  <!-- Corregido si el modelo es 'material' -->
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menú para Materials (Dentro del menú de Productos) -->
    <menuitem
        name="Materials"
        id="menu_stickers_material"
        parent="product.menu_catalog"
        sequence="60"
        action="action_stickers_material_list"
    />

    <!-- Herencia de la Vista de Product Template -->
    <record id="view_material_product_template_form" model="ir.ui.view">
        <field name="name">material.product.template.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/> <!-- Verificar ID correcto -->
        <field name="arch" type="xml">

            <!-- Agregar los campos de Material en la pestaña de "Inventario" -->
            <xpath expr="//page[@name='inventory']" position="inside">
                <group string="Información de Material">
                    <field name="tipo_material"/>
                    <field name="proveedor_principal_id"/>
                    <field name="costo_por_unidad"/>
                    <field name="especificaciones_tecnicas"/>
                    <field name="fecha_ultima_compra"/>
                    <field name="cantidad_disponible" readonly="1"/>
                    <field name="unidad_medida"/>
                    <field name="cantidad_en_m2" readonly="1"/>
                </group>
            </xpath>

            <!-- Nueva pestaña para escalas (solo para materiales) -->
            <xpath expr="//notebook" position="inside">
                <page string="Escala de Conversión" attrs="{'invisible': [('es_material', '=', False)]}">
                    <group>
                        <field name="escala_id"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
